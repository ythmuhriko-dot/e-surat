{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/logo_sby.svg",
      "dest": "/logo_sby.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}