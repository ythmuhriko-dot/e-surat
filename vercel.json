{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/login.php"
    },
    {
      "src": "/(.*)\\.php",
      "status": 301,
      "headers": {
        "Location": "/$1"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}